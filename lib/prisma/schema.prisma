datasource db {
    provider = "postgresql"
}

generator client {
    provider = "prisma-client-js"
}

enum TradeStatus {
    BOUGHT
    SOLD
}

enum TradeOptions {
    BUY
    SELL
}

enum MarketVariant {
    DEFAULT
    SPORTS_TEAM_MATCH
    CRYPTO_UP_DOWN
}

enum BuyTradeType {
    YES
    NO
    AVG_PRICE
    NA
}

enum SlugMatchType {
    PREFIX
    SUFFIX
    REGEX
}

enum BetStatus {
    ACTIVE
    INACTIVE
}

model Trade {
    id Int @id() @default(autoincrement())
    marketId Int
    slug String
    marketSlug String?
    outcomeOnChainId String?
    buyAmount Int
    buyAmountInUsd Decimal
    buyOrderHash String
    sellOrderHash String?
    buyTimestamp DateTime
    sellAmount Int?
    sellAmountInUsd Decimal?
    sellTimestamp DateTime?
    profitOrLossInUsd Decimal?
    status TradeStatus

    @@index([marketId, status, buyTimestamp])
}

model MarketProfile {
    id Int @id() @default(autoincrement())
    marketVariant MarketVariant
    configKey String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt()
    buyConfig BuyPositionConfig?
    sellConfig SellPositionConfig?
    sportsBets SportsBet[]
    cryptoBets CryptoBet[]

    @@unique([marketVariant, configKey])
}

model BuyPositionConfig {
    id Int @id() @default(autoincrement())
    marketProfileId Int @unique()
    amount Int
    entry Int
    tradeType BuyTradeType @default(AVG_PRICE)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt()
    marketProfile MarketProfile @relation(fields: [marketProfileId], references: [id], onDelete: Cascade)
}

model SellPositionConfig {
    id Int @id() @default(autoincrement())
    marketProfileId Int @unique()
    stopLossPercentage Int
    amountPercentage Int
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt()
    marketProfile MarketProfile @relation(fields: [marketProfileId], references: [id], onDelete: Cascade)
}

model WalletApproval {
    id Int @id() @default(autoincrement())
    walletAddress String
    timestamp DateTime
}

model SportsBet {
    id Int @id() @default(autoincrement())
    marketProfileId Int
    keyword String
    category String
    status BetStatus @default(ACTIVE)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt()
    marketProfile MarketProfile @relation(fields: [marketProfileId], references: [id], onDelete: Cascade)

    @@unique([marketProfileId, category, keyword])
}

model CryptoBet {
    id Int @id() @default(autoincrement())
    marketProfileId Int
    matchType SlugMatchType
    pattern String
    status BetStatus @default(ACTIVE)
    enabled Boolean @default(true)
    priority Int @default(100)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt()
    marketProfile MarketProfile @relation(fields: [marketProfileId], references: [id], onDelete: Cascade)

    @@unique([marketProfileId, matchType, pattern])
    @@index([enabled, priority])
    @@map("SlugMatchRule")
}