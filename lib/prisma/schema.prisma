generator client {
  provider = "prisma-client"
  output   = "../../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum TradeStatus {
  BOUGHT
  SOLD
}

enum TradeOptions {
  BUY
  SELL
}

enum MarketVariant {
  DEFAULT
  SPORTS_MATCH
  CRYPTO_UP_DOWN
}

model Trade {
  id                Int        @id @default(autoincrement())
  marketId          Int
  slug              String
  buyAmount         Int
  buyAmountInUsd    Decimal   @db.Decimal(18, 2)
  buyOrderHash      String
  buyTimestamp      DateTime
  sellAmount        Int?
  sellAmountInUsd   Decimal?  @db.Decimal(18, 2)
  sellOrderHash     String?
  sellTimestamp     DateTime?
  profitOrLossInUsd Decimal?  @db.Decimal(18, 2)
  status            TradeStatus
}

model BuyPositionConfig {
  id                Int          @id @default(autoincrement())
  marketVariant     MarketVariant
  slugWithSuffix    String
  amount            Int
  entry             Int
}

model SellPositionConfig {
  id                  Int         @id @default(autoincrement())
  marketVariant       MarketVariant
  slugWithSuffix      String
  stopLossPercentage  Int
  amountPercentage    Int
}

model WalletApproval {
  id              Int         @id @default(autoincrement())
  walletAddress   String
  timestamp       DateTime
}

